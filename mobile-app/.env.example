# Backend Environment Variables
GOOGLE_CLIENT_ID=your_google_web_client_id_here

# Get credentials from: https://console.cloud.google.com
# 1. Create a new project
# 2. Enable Google+ API
# 3. Create OAuth 2.0 credentials
# 4. Add authorized redirect URIs:
#    - http://localhost:5000/api/oauth/google/callback
#    - Your production URL

# Mobile App Client IDs (update in LoginScreen.js)
# EXPO_CLIENT_ID=your_expo_client_id
# IOS_CLIENT_ID=your_ios_client_id
# ANDROID_CLIENT_ID=your_android_client_id
# WEB_CLIENT_ID=same_as_backend_google_client_id
